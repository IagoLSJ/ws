# Database (Railway PostgreSQL add-on fornece a DATABASE_URL automaticamente)
DATABASE_URL=postgresql://user:pass@host:5432/multinegocio

# Redis (Railway Redis add-on fornece a REDIS_URL automaticamente)
REDIS_URL=redis://host:6379

# Storage (usar Cloudflare R2 ou AWS S3 em produção)
MINIO_ENDPOINT=account.r2.cloudflarestorage.com
MINIO_PORT=443
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=multinegocio
MINIO_PUBLIC_URL=https://pub-1234.r2.dev
MINIO_USE_SSL=true

# JWT
JWT_SECRET=gerar-uma-chave-forte-aqui
JWT_REFRESH_SECRET=gerar-outra-chave-forte-aqui
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# API
API_PORT=3000
API_URL=https://seu-backend.railway.app
CORS_ORIGIN=https://seu-frontend.railway.app

# Frontend (para build do frontend saber onde fica a API)
VITE_API_URL=https://seu-backend.railway.app

# n8n (opcional)
N8N_API_KEY=change-me-n8n-api-key

# SMTP (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@multinegocio.app
