# ─── Backend (Render) ───────────────────────────────────────
# Render PostgreSQL: o próprio Render injeta a DATABASE_URL automagicamente
DATABASE_URL=postgresql://user:pass@host:5432/multinegocio

# Redis (Upstash - serverless, free 10MB)
REDIS_URL=redis://default:password@upstash-host:6379

# JWT
JWT_SECRET=cole-aqui-uma-chave-forte-de-64-caracteres
JWT_REFRESH_SECRET=cole-aqui-outra-chave-forte-de-64-caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS (Vercel frontend)
CORS_ORIGIN=https://multinegocio.vercel.app

# Storage (Supabase S3-compatible)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_S3_ENDPOINT=https://seu-projeto.storage.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=cole-a-sua-access-key
SUPABASE_S3_SECRET_KEY=cole-a-sua-secret-key
SUPABASE_BUCKET=multinegocio
SUPABASE_S3_REGION=us-east-1

# n8n (opcional)
N8N_API_KEY=change-me

# SMTP (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@multinegocio.app

# ─── Frontend (Vercel) ──────────────────────────────────────
# VITE_API_URL é usada no build do frontend (no Vercel, setar nas Environment Variables)
# Deve apontar para o backend no Render
VITE_API_URL=https://multinegocio-api.onrender.com
